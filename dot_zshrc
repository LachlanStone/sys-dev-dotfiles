fi

# Remove duplicate entries from PATH while preserving order
path_remove_dups() {
	local p
	local -a list
	local -A seen
	IFS=:
	for p in ${(@s/:/)PATH}; do
		if [[ -n $p && -z ${seen[$p]} ]]; then
			list+=($p)
			seen[$p]=1
		fi
	done
	PATH=${(j/:/)list}
	unset IFS list seen p
}
path_remove_dups

